# ============================================================
# Hermès Production Compose Env
#
# Copy to .env.prod and fill in real values. .env.prod is gitignored;
# .env.prod.example is the committed reference operators copy from.
#
# ============================================================

# ── Image version ───────────────────────────────────────────
# Pin to a git tag in real prod; `latest` is fine for local-VPS hacking.
HERMES_VERSION=latest

# ── Postgres ────────────────────────────────────────────────
POSTGRES_DB=hermes
POSTGRES_USER=hermes
# DATABASE_URL is what every Go service actually consumes. The password
# segment is interpolated from .env.prod here, not from the Docker secret
# — see docs/runbooks/secret-management.md §PG-PASSWORD for the rationale.
# Generate the password with:
#   openssl rand -base64 32 | tr -d '=+/\n'
# and then put it BOTH in this URL AND in deploy/secrets/prod/postgres-password
# (the latter is what `postgres:17-alpine` reads via POSTGRES_PASSWORD_FILE).
DATABASE_URL=postgres://hermes:CHANGE_ME_STRONG_PG_PASSWORD@postgres:5432/hermes?sslmode=disable

# ── Per-pod identity ─────────────────────────────────────────
# Override for multi-replica deploys (must be unique per replica).
POD_ID_MBS=hermes-mbs-prod-0
POD_ID_WA=hermes-wa-prod-0

# ── MBS operational tuning ──────────────────────────────────
MBS_BRIDGE_MAX_CONCURRENT=10
MBS_STREAM_REPLICAS=1

# ── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info

# ── Public-facing surface ───────────────────────────────────
# Host port for the in-stack nginx web container. Default 80 = direct
# expose; set to 8080 (or another unprivileged port) and front with
# Caddy/nginx for TLS termination (chunk 5).
HERMES_WEB_PORT=80
HERMES_GATEWAY_GRPC_PORT=8080
HERMES_GATEWAY_HTTP_PORT=8081

# Used by chunk-5 Caddy/nginx reverse proxy config.
HERMES_DOMAIN=hermes.example.com
