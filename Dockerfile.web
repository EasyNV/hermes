# Dockerfile.web — production build of the React SPA.
#
# Two-stage:
#   1. node:22-alpine builder runs `npm ci && npm run build` → web/dist/
#   2. nginx:alpine runtime serves web/dist on :80 with SPA fallback
#
# Build:
#   docker build -f Dockerfile.web \
#     --build-arg VERSION=$(git describe --tags --always --dirty) \
#     --build-arg REVISION=$(git rev-parse HEAD) \
#     --build-arg CREATED=$(date -u +%Y-%m-%dT%H:%M:%SZ) \
#     -t hermes-web:latest .
#
# nginx server config: deploy/nginx/web.conf
# Reverse-proxy fronting (TLS, /api/*, /ws) is chunk 5's responsibility.

# ─── Stage 1: SPA build ──────────────────────────────────────────────────────
FROM node:22-alpine AS builder

WORKDIR /src

# Cache npm install: copy manifests first, install, then copy source.
COPY web/package.json web/package-lock.json* ./
RUN npm ci

COPY web/ .
RUN npm run build

# ─── Stage 2: nginx runtime ──────────────────────────────────────────────────
FROM nginx:alpine

# Replace the stock site config with the SPA-aware one.
COPY deploy/nginx/web.conf /etc/nginx/conf.d/default.conf

# Drop the built assets into nginx's default doc root.
COPY --from=builder /src/dist /usr/share/nginx/html

# nginx:alpine runs the master as root and workers as nginx (UID 101) by
# default. That's fine for a stateless static-asset container; no override
# needed. The container reverse-proxy in chunk 5 sits in front of this and
# terminates TLS.

EXPOSE 80

# OCI labels.
ARG VERSION=dev
ARG REVISION=
ARG CREATED=

LABEL org.opencontainers.image.title="hermes-web" \
      org.opencontainers.image.source="https://github.com/hermes-waba/hermes" \
      org.opencontainers.image.version="${VERSION}" \
      org.opencontainers.image.revision="${REVISION}" \
      org.opencontainers.image.created="${CREATED}" \
      org.opencontainers.image.vendor="hermes-waba"
